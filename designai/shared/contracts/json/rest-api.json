{
  "_meta": { "dialect": "json-schema-draft-07", "id": "rest-api" },
  "title": "DesignAI REST API Contracts (v1)",
  "description": "Frozen request/response schemas for all REST endpoints. Source of truth for ajv (frontend) and Pydantic (backend).",
  "definitions": {
    "UploadRequest": {
      "type": "object",
      "required": ["filename", "contentType"],
      "properties": {
        "filename": { "type": "string" },
        "contentType": { "type": "string", "enum": ["image/jpeg", "image/png", "image/webp"] },
        "roomType": { "type": "string" },
        "budget": { "type": "number" },
        "style": { "type": "string" }
      }
    },
    "UploadResponse": {
      "type": "object",
      "required": ["projectId", "uploadUrl", "imageKey"],
      "properties": {
        "projectId": { "type": "string" },
        "uploadUrl": { "type": "string" },
        "imageKey": { "type": "string" }
      }
    },
    "ProjectCreateRequest": {
      "type": "object",
      "required": ["roomType"],
      "properties": {
        "title": { "type": "string" },
        "roomType": { "type": "string" },
        "budget": { "type": "number" },
        "style": { "type": "string" }
      }
    },
    "ProjectResponse": {
      "type": "object",
      "required": ["projectId", "userId", "status", "createdAt"],
      "properties": {
        "projectId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["created", "uploading", "analyzing", "recommendations_ready", "editing", "rendering", "completed"] },
        "roomType": { "type": "string" },
        "budget": { "type": "number" },
        "style": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "StyleRequest": {
      "type": "object",
      "required": ["projectId"],
      "properties": {
        "projectId": { "type": "string" },
        "inspirationImageKeys": { "type": "array", "items": { "type": "string" } },
        "preferredStyle": { "type": "string" }
      }
    },
    "RenderRequest": {
      "type": "object",
      "required": ["projectId", "selectedTheme"],
      "properties": {
        "projectId": { "type": "string" },
        "selectedTheme": { "type": "string" },
        "sceneJson": { "type": "object" }
      }
    },
    "RenderResponse": {
      "type": "object",
      "required": ["jobId", "status"],
      "properties": {
        "jobId": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "processing", "completed", "failed", "timeout"] },
        "message": { "type": "string" }
      }
    },
    "RecommendationsResponse": {
      "type": "object",
      "required": ["recommendations"],
      "properties": {
        "analysis": { "$ref": "#/definitions/RoomAnalysis" },
        "recommendations": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/definitions/DesignRecommendation" }
        }
      }
    },
    "RoomAnalysis": {
      "type": "object",
      "properties": {
        "roomType": { "type": "string" },
        "estimatedDimensions": {
          "type": "object",
          "properties": { "width": { "type": "number" }, "length": { "type": "number" }, "height": { "type": "number" } }
        },
        "currentStyle": { "type": "string" },
        "lightingQuality": { "type": "string" },
        "detectedObjects": { "type": "array", "items": { "type": "string" } },
        "colorPalette": { "type": "array", "items": { "type": "string" } }
      }
    },
    "DesignRecommendation": {
      "type": "object",
      "required": ["theme", "description"],
      "properties": {
        "theme": { "type": "string" },
        "type": { "type": "string", "enum": ["closest_to_inspiration", "budget_optimized", "creative_reinterpretation"] },
        "description": { "type": "string" },
        "colorScheme": { "type": "array", "items": { "type": "string" } },
        "suggestedMaterials": { "type": "array", "items": { "type": "string" } },
        "estimatedCost": { "type": "number" },
        "reasoning": { "type": "string" }
      }
    },
    "SaveSceneRequest": {
      "type": "object",
      "required": ["projectId", "sceneDescriptor"],
      "properties": {
        "projectId": { "type": "string" },
        "sceneDescriptor": { "type": "object" }
      }
    },
    "DeleteResponse": {
      "type": "object",
      "required": ["message", "projectId"],
      "properties": {
        "message": { "type": "string" },
        "projectId": { "type": "string" }
      }
    }
  }
}
