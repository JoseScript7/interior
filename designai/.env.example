# DesignAI Environment Variables
# Copy to .env and fill in values (NEVER commit .env to git)

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=REPLACE_WITH_ACCOUNT_ID

# Cognito
COGNITO_USER_POOL_ID=REPLACE
COGNITO_CLIENT_ID=REPLACE

# S3
UPLOADS_BUCKET=designai-uploads-REPLACE
RENDERS_BUCKET=designai-renders-REPLACE
ASSETS_BUCKET=designai-assets-REPLACE

# Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# SageMaker
SAGEMAKER_CONTROLNET_ENDPOINT=designai-controlnet-endpoint
SAGEMAKER_MIDAS_ENDPOINT=designai-midas-endpoint
SAGEMAKER_TRIPOSR_ENDPOINT=designai-triposr-endpoint

# OpenSearch
OPENSEARCH_ENDPOINT=REPLACE

# DynamoDB
PROJECTS_TABLE=designai-projects

# SQS
ANALYSIS_QUEUE_URL=REPLACE
RENDER_QUEUE_URL=REPLACE

# WebSocket
WEBSOCKET_ENDPOINT=REPLACE

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=REPLACE
NEXT_PUBLIC_CLOUDFRONT_URL=REPLACE
